FLASK_ENV=development
SECRET_KEY=replace-with-a-long-random-value
DATABASE_PATH=database/triage.db
LOG_FILE=logs/triage.log

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta
GEMINI_COST_PER_1K_INPUT_TOKENS=0.000075
GEMINI_COST_PER_1K_OUTPUT_TOKENS=0.0003

# Business assumptions for impact measurement
DEFAULT_HOURLY_RATE=55
AUTOMATION_SUCCESS_HOURS_SAVED=1.5
AUTOMATION_FAILURE_HOURS_SAVED=0.1

# Google Workspace integration
# Put a service account JSON file path here when exporting to Google APIs.
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_DOCS_FOLDER_ID=
